<?php

/**
 * @file
 * Contains orbit_media.module.
 */

declare(strict_types=1);

use Drupal\Core\Form\FormStateInterface;
use Drupal\Core\Url;
use Drupal\Core\Entity\EntityInterface;

/**
 * Implements hook_theme().
 */
function orbit_media_theme($existing, $type, $theme, $path): array {
  return [
    'media__image__default' => [
      'base hook' => 'media',
      'template' => 'media--image--default',
      'path' => $path . '/templates',
    ],
    'media__image__inline_image' => [
      'base hook' => 'media',
      'template' => 'media--image--inline-image',
      'path' => $path . '/templates',
    ],
    'field__media__field_media_image' => [
      'base hook' => 'field',
      'template' => 'field--media--field-media-image',
      'path' => $path . '/templates',
    ],
  ];
}

/**
 * Implements hook_form_alter().
 */
function orbit_media_form_alter(&$form, FormStateInterface $form_state, $form_id): void {
  // Add cancel button to media entity edit forms.
  if ($form_id === 'media_image_edit_form' || strpos($form_id, 'media_') === 0 && strpos($form_id, '_edit_form') !== FALSE) {
    // Attach custom button styles library.
    $form['#attached']['library'][] = 'orbit_media/buttons';

    $form['actions']['cancel'] = [
      '#type' => 'link',
      '#title' => t('Cancel'),
      '#url' => _orbit_media_get_cancel_url(),
      '#attributes' => [
        'class' => [
          'button',
          'button--secondary',
          'orbit-media-small-button-reset',
        ],
      ],
      '#weight' => 100,
    ];
  }
}

/**
 * @param $form
 * @param \Drupal\Core\Form\FormStateInterface $form_state
 * @param $form_id
 *
 * @return void
 */
function orbit_media_form_media_image_edit_form_alter(&$form, FormStateInterface $form_state, $form_id): void {
  $form['field_width']['widget'][0]['value']['#disabled'] = TRUE;
  $form['field_height']['widget'][0]['value']['#disabled'] = TRUE;
}

/**
 * @param $form
 * @param \Drupal\Core\Form\FormStateInterface $form_state
 * @param $form_id
 *
 * @return void
 */
function orbit_media_form_media_image_add_form_alter(&$form, FormStateInterface $form_state, $form_id): void {
  $form['field_width']['widget'][0]['value']['#disabled'] = TRUE;
  $form['field_height']['widget'][0]['value']['#disabled'] = TRUE;
}

/**
 * Helper function to get the cancel button redirect URL.
 */
function _orbit_media_get_cancel_url(): Url {
  $request = \Drupal::request();

  // Check for destination parameter first.
  $destination = $request->query->get('destination');
  if ($destination) {
    return Url::fromUserInput($destination);
  }

  // Fall back to referrer.
  $referer = $request->headers->get('referer');
  if ($referer) {
    return Url::fromUri($referer);
  }

  // Fall back to media list.
  return Url::fromRoute('system.admin_content');
}

/**
 * Implements hook_entity_operation().
 *
 * - Offer media image download
 */
function orbit_media_entity_operation(EntityInterface $entity) {
  $operations = [];

  if ($entity->getEntityTypeId() === 'media') {
    if ($entity->hasField('field_media_image') && !$entity->get('field_media_image')
        ->isEmpty()) {
      $file = $entity->get('field_media_image')->entity;
      if ($file) {
        $uri = $file->getFileUri();
        $url = \Drupal::service('file_url_generator')
          ->generateAbsoluteString($uri);

        $operations['download'] = [
          'title' => t('Download'),
          'url' => Url::fromUri($url),
          'weight' => 50,
          'attributes' => [
            'download' => TRUE,
          ],
        ];
      }
    }

    if ($entity->hasField('field_media_video_file') && !$entity->get('field_media_video_file')
        ->isEmpty()) {
      $file = $entity->get('field_media_video_file')->entity;
      if ($file) {
        $uri = $file->getFileUri();
        $url = \Drupal::service('file_url_generator')
          ->generateAbsoluteString($uri);

        $operations['download'] = [
          'title' => t('Download'),
          'url' => Url::fromUri($url),
          'weight' => 50,
          'attributes' => [
            'download' => TRUE,
          ],
        ];
      }
    }
  }

  return $operations;
}

/**
 * Implements hook_ENTITY_TYPE_presave() for media entities.
 *
 * Save some basic image dimention data to the media entity so we can use it
 * in views.
 */
function orbit_media_media_presave(\Drupal\media\MediaInterface $media) {
  // Only act on new entities (insert, not update).
  if (!$media->isNew()) {
    return;
  }

  // Only act on a specific bundle.
  if ($media->bundle() !== 'image') {
    return;
  }

  $item = $media->get('field_media_image')->first();

  $media->set('field_width', $item->width);
  $media->set('field_height', $item->height);
}

function orbit_media_logo_svg_url(): string {
  $module_path = \Drupal::service('extension.list.module')
    ->getPath('orbit_media');
  return \Drupal::service('file_url_generator')
    ->generateString($module_path . '/assets/logo.svg');
}

/**
 * Common footer function for Oyster admin pages.
 */
function orbit_media_page_footer(): array {
  $build['footer'] = [
    '#markup' => '<img src="' . orbit_media_logo_svg_url() . '" alt="Oyster design logo" align="right" width="148" height="45" />',
  ];
  return $build;
}